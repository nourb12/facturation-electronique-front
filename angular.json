{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "tunisflow": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "type": "component"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {

        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/tunisflow",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",

            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": ""
              },
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              }
            ],

            "styles": [
              "src/styles.scss"
            ],
            "scripts": [],
            "allowedCommonJsDependencies": [
              "canvg",
              "jspdf",
              "core-js",
              "raf",
              "rgbcolor",
              "dompurify",
              "html2canvas"
            ]
          },

          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "24kB",
                  "maximumError": "48kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },

            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },

          "defaultConfiguration": "development"
        },

        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "tunisflow:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "tunisflow:build:production"
            },
            "development": {
              "buildTarget": "tunisflow:build:development"
            }
          },
          "defaultConfiguration": "development"
        },

        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json"
          }
        }

      }
    }
  }
}
